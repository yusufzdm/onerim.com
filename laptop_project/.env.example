OPENAI_API_KEY=your_key
OPENAI_MODEL=gpt-4o-mini

# Laptop öneri DB (ana asistan)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=laptops
MONGODB_COLLECTION=items

# Optional field overrides
PRICE_FIELD=price
NAME_FIELD=name
BRAND_FIELD=brand
MAX_FETCH=200

# PC Builder DB (buildcores_db, MongoDB Atlas önerilir)
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority
MONGO_DB_NAME=buildcores_db

# CORS (frontend dev sunucuları)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Debug endpoints (SADECE lokal geliştirme). Aktif olduğunda /chat/history/{thread_id}
# kimlik doğrulamasız olarak açılır — prod'da ASLA true yapma.
ENABLE_DEBUG_ENDPOINTS=false
